#!/usr/bin/env bash
# =============================================================================
# pre-push hook: Dual Quality Gate v3 (enterprise)
# =============================================================================
#
# GUARD 1: Champion Badge Regression Guard
#   BUSINESS RULE: CHAMPION badge must NEVER display "No ranking data"
#
# GUARD 2: Critical E2E Suite Validation (main/develop only)
#   BUSINESS RULE: 170 critical E2E tests must pass before pushing to main/develop
#
# Lifecycle (fully self-contained):
#   1. Acquire lockfile  (prevents parallel hook runs)
#   2. Check FastAPI backend is reachable  (required, not managed here)
#   3. Start a dedicated Streamlit instance on TEST_PORT (default 8599)
#      → isolates the test from any running dev instance on 8501
#   4. Wait for Streamlit readiness  (retry loop, START_TIMEOUT seconds)
#   5. Run the Playwright E2E regression test (Champion badge)
#   6. [NEW] Run Critical E2E Suite if pushing to main/develop (170 tests)
#   7. Cleanup:  stop Streamlit + release lockfile  (trap EXIT/INT/TERM)
#
# Overriding  (emergency use only):
#   SKIP_CHAMPION_CHECK=1 SKIP_REASON="<explanation>" git push
#   SKIP_CRITICAL_E2E=1 SKIP_REASON="<explanation>" git push
#   • Both env vars are REQUIRED when skipping.
#   • Every skip is appended to .git/hooks/champion_skip_audit.log
#   • Skips without SKIP_REASON are BLOCKED.
#
# Tunable env vars:
#   CHAMPION_TEST_PORT      port for dedicated Streamlit (default: 8599)
#   CHAMPION_START_TIMEOUT  seconds to wait for readiness (default: 45)
#   CHAMPION_DB_URL         DATABASE_URL for the Streamlit process
#                           (defaults to lfa_intern_system connection string)
#   API_BASE_URL            FastAPI URL to health-check (default: http://localhost:8000)
#
# Installation:
#   ./hooks/install-hooks.sh
# =============================================================================

set -uo pipefail

# ── Colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

err()  { echo -e "${RED}${BOLD}❌  $*${NC}" >&2; }
warn() { echo -e "${YELLOW}⚠️   $*${NC}" >&2; }
info() { echo -e "   $*"; }
ok()   { echo -e "   ${GREEN}✅  $*${NC}"; }

# ── Config ────────────────────────────────────────────────────────────────────
REPO_ROOT="$(git rev-parse --show-toplevel)"
TEST_PORT="${CHAMPION_TEST_PORT:-8599}"
START_TIMEOUT="${CHAMPION_START_TIMEOUT:-45}"
RETRY_INTERVAL=2
API_URL="${API_BASE_URL:-http://localhost:8000}"
DEFAULT_DB_URL="postgresql://postgres:postgres@localhost:5432/lfa_intern_system"
DB_URL="${CHAMPION_DB_URL:-${DEFAULT_DB_URL}}"

LOCKFILE="/tmp/champion_guard_${TEST_PORT}.lock"
AUDIT_LOG="${REPO_ROOT}/.git/hooks/champion_skip_audit.log"
TEST_FILE="${REPO_ROOT}/tests_e2e/test_champion_badge_regression.py"
VENV_ACTIVATE="${REPO_ROOT}/venv/bin/activate"
HOME_PY="${REPO_ROOT}/streamlit_app/🏠_Home.py"

STREAMLIT_PID=""

# ── Cleanup trap ──────────────────────────────────────────────────────────────
cleanup() {
    local exit_code=$?
    if [[ -n "${STREAMLIT_PID}" ]] && kill -0 "${STREAMLIT_PID}" 2>/dev/null; then
        kill "${STREAMLIT_PID}" 2>/dev/null || true
        # Brief wait so the port is released before the shell exits
        local waited=0
        while kill -0 "${STREAMLIT_PID}" 2>/dev/null && [[ ${waited} -lt 5 ]]; do
            sleep 1
            waited=$((waited + 1))
        done
    fi
    rm -f "${LOCKFILE}"
    exit "${exit_code}"
}
trap cleanup EXIT INT TERM

# ─────────────────────────────────────────────────────────────────────────────
# 0.  SKIP override  (requires SKIP_REASON + writes audit log)
# ─────────────────────────────────────────────────────────────────────────────
if [[ "${SKIP_CHAMPION_CHECK:-0}" == "1" ]]; then
    if [[ -z "${SKIP_REASON:-}" ]]; then
        err "SKIP_CHAMPION_CHECK=1 requires SKIP_REASON to be set."
        err "Example:  SKIP_CHAMPION_CHECK=1 SKIP_REASON=\"docs-only change\" git push"
        exit 1
    fi

    mkdir -p "$(dirname "${AUDIT_LOG}")"
    printf '%s  SKIP  branch=%s  user=%s  reason=%s\n' \
        "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
        "$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')" \
        "$(git config user.email 2>/dev/null || echo 'unknown')" \
        "${SKIP_REASON}" \
        >> "${AUDIT_LOG}"

    echo ""
    warn "Champion guard SKIPPED — recorded in audit log"
    warn "Skip reason : ${SKIP_REASON}"
    warn "Audit log   : ${AUDIT_LOG}"
    echo ""
    exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# 0a.  Scope-based auto-skip
#
#      The Champion badge can only regress when production code changes.
#      Pure test / doc / CI commits cannot affect it → auto-skip guard.
#
#      Changed-file detection (no stdin consumed — Guard 2 still reads it):
#        existing branch → diff vs refs/remotes/<remote>/<branch>   (push range)
#        new branch      → diff vs merge-base with origin/main
#        fallback        → empty _scope_changed → full guard runs (safe default)
#
#      Production paths that require the full guard:
#        app/**  streamlit_app/**  services/**  scripts/**
#        alembic/**  requirements*  Dockerfile*  docker-compose*
# ─────────────────────────────────────────────────────────────────────────────
_PROD_PATTERN='^(app|backend|services|streamlit_app|scripts|alembic|requirements|Dockerfile|docker-compose)'

_remote_name="${1:-origin}"
_current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
_scope_changed=""

if [[ -n "${_current_branch}" && "${_current_branch}" != "HEAD" ]]; then
    _remote_tip=$(git rev-parse --verify \
        "refs/remotes/${_remote_name}/${_current_branch}" 2>/dev/null || echo "")
    if [[ -n "${_remote_tip}" ]]; then
        # Existing branch: all commits not yet on remote
        _scope_changed=$(git diff --name-only "${_remote_tip}" HEAD 2>/dev/null || true)
    else
        # New branch: everything since it diverged from main
        _merge_base=$(git merge-base HEAD \
            "refs/remotes/${_remote_name}/main" 2>/dev/null \
            || git merge-base HEAD "refs/remotes/origin/main" 2>/dev/null \
            || echo "")
        if [[ -n "${_merge_base}" ]]; then
            _scope_changed=$(git diff --name-only "${_merge_base}" HEAD 2>/dev/null || true)
        fi
        # Empty _scope_changed → cannot determine → full guard (safe default)
    fi
fi

if [[ -n "${_scope_changed}" ]]; then
    if ! echo "${_scope_changed}" | grep -qE "${_PROD_PATTERN}"; then
        _first_files=$(echo "${_scope_changed}" | grep -v '^$' | head -4 | tr '\n' ',' | sed 's/,$//')
        mkdir -p "$(dirname "${AUDIT_LOG}")"
        printf '%s  AUTO-SKIP  branch=%s  user=%s  scope=non-production  files=[%s]\n' \
            "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
            "$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')" \
            "$(git config user.email 2>/dev/null || echo 'unknown')" \
            "${_first_files}" \
            >> "${AUDIT_LOG}"
        echo ""
        warn "Champion guard AUTO-SKIPPED — no production paths changed"
        info "Changed : ${_first_files}"
        info "Pattern : ${_PROD_PATTERN}"
        info "Audit   : ${AUDIT_LOG}"
        echo ""
        exit 0
    fi
    info "Production paths detected — running full Champion guard"
fi

# ─────────────────────────────────────────────────────────────────────────────
# Banner
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}${BOLD}  🏆 Champion Badge Regression Guard v2  (pre-push)${NC}"
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# ─────────────────────────────────────────────────────────────────────────────
# 0b. Docker fast-path (preferred when Docker is available)
#     Runs the fully containerised test stack; skips native lifecycle below.
# ─────────────────────────────────────────────────────────────────────────────
COMPOSE_FILE="${REPO_ROOT}/docker-compose.test.yml"
if command -v docker &>/dev/null && [[ -f "${COMPOSE_FILE}" ]]; then
    ok "Docker detected — using containerised test stack"
    cd "${REPO_ROOT}"
    if docker compose -f "${COMPOSE_FILE}" up \
            --build \
            --abort-on-container-exit \
            --exit-code-from e2e-tests \
            2>&1; then
        docker compose -f "${COMPOSE_FILE}" down -v --remove-orphans 2>/dev/null || true
        echo ""
        echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${GREEN}${BOLD}  ✅ CHAMPION guard PASSED (Docker)${NC}"
        echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        # Continue to critical E2E validation (don't exit yet)
    else
        docker compose -f "${COMPOSE_FILE}" down -v --remove-orphans 2>/dev/null || true
        echo ""
        echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${RED}${BOLD}  ❌ CHAMPION guard FAILED (Docker) — PUSH BLOCKED${NC}"
        echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        echo "  Screenshot: tests_e2e/screenshots/champion_badge_FAILED.png"
        echo ""
        exit 1
    fi
fi
warn "Docker not available — running in NON-CANONICAL fallback mode"
warn "The Docker stack (docker-compose.test.yml) is the single source of truth."
warn "Install Docker to guarantee a reproducible, fully isolated test environment."
warn "Results in this mode depend on your local DB state and running services."
echo ""

# ─────────────────────────────────────────────────────────────────────────────
# 1.  Lockfile  (prevent parallel runs on the same port)
# ─────────────────────────────────────────────────────────────────────────────
if [[ -f "${LOCKFILE}" ]]; then
    old_pid=$(cat "${LOCKFILE}" 2>/dev/null || echo "")
    if [[ -n "${old_pid}" ]] && kill -0 "${old_pid}" 2>/dev/null; then
        err "Another champion guard run is already in progress (PID ${old_pid})."
        err "If that is stale, delete: ${LOCKFILE}"
        exit 1
    else
        warn "Stale lockfile found — removing."
        rm -f "${LOCKFILE}"
    fi
fi
echo $$ > "${LOCKFILE}"

# ─────────────────────────────────────────────────────────────────────────────
# 2.  Activate venv
# ─────────────────────────────────────────────────────────────────────────────
if [[ -f "${VENV_ACTIVATE}" ]]; then
    # shellcheck disable=SC1090
    source "${VENV_ACTIVATE}"
    ok "Virtual environment activated"
else
    warn "No venv found at ${VENV_ACTIVATE} — relying on system Python"
fi

# ─────────────────────────────────────────────────────────────────────────────
# 3.  Check Playwright
# ─────────────────────────────────────────────────────────────────────────────
if ! python3 -c "import playwright" 2>/dev/null; then
    err "Playwright not found."
    info "Install: pip install playwright pytest-playwright && playwright install chromium"
    info ""
    info "Push blocked. Fix the installation or use:"
    info "  SKIP_CHAMPION_CHECK=1 SKIP_REASON=\"no playwright\" git push"
    exit 1
fi
ok "Playwright found"

# ─────────────────────────────────────────────────────────────────────────────
# 4.  Check FastAPI backend (required — we do NOT manage it)
# ─────────────────────────────────────────────────────────────────────────────
info "Checking FastAPI backend at ${API_URL} ..."
if ! curl -sf "${API_URL}/docs" > /dev/null 2>&1 && \
   ! curl -sf "${API_URL}/health" > /dev/null 2>&1 && \
   ! curl -sf "${API_URL}/" > /dev/null 2>&1; then
    err "FastAPI backend not reachable at ${API_URL}"
    info ""
    info "Start the backend before pushing:"
    info "  DATABASE_URL=${DB_URL} \\"
    info "    uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
    info ""
    info "Push blocked. Start the backend or use:"
    info "  SKIP_CHAMPION_CHECK=1 SKIP_REASON=\"backend down\" git push"
    exit 1
fi
ok "FastAPI backend reachable"

# ─────────────────────────────────────────────────────────────────────────────
# 5.  Start dedicated Streamlit on TEST_PORT  (background)
# ─────────────────────────────────────────────────────────────────────────────
info "Starting dedicated Streamlit on port ${TEST_PORT} ..."
STREAMLIT_LOG="/tmp/champion_streamlit_${TEST_PORT}.log"

DATABASE_URL="${DB_URL}" \
API_BASE_URL="${API_URL}" \
python3 -m streamlit run "${HOME_PY}" \
    --server.port "${TEST_PORT}" \
    --server.headless true \
    --server.address localhost \
    --browser.gatherUsageStats false \
    > "${STREAMLIT_LOG}" 2>&1 &
STREAMLIT_PID=$!

# ─────────────────────────────────────────────────────────────────────────────
# 6.  Wait for Streamlit readiness  (retry loop)
# ─────────────────────────────────────────────────────────────────────────────
ELAPSED=0
READY=0
while [[ ${ELAPSED} -lt ${START_TIMEOUT} ]]; do
    if curl -sf "http://localhost:${TEST_PORT}" > /dev/null 2>&1; then
        READY=1
        break
    fi
    # If the process died early, abort immediately
    if ! kill -0 "${STREAMLIT_PID}" 2>/dev/null; then
        err "Streamlit process exited unexpectedly."
        info "Log: ${STREAMLIT_LOG}"
        exit 1
    fi
    sleep "${RETRY_INTERVAL}"
    ELAPSED=$((ELAPSED + RETRY_INTERVAL))
    info "  Waiting for Streamlit... (${ELAPSED}/${START_TIMEOUT}s)"
done

if [[ ${READY} -eq 0 ]]; then
    err "Streamlit did not become ready within ${START_TIMEOUT}s."
    info "Log: ${STREAMLIT_LOG}"
    info ""
    info "Try increasing the timeout:"
    info "  CHAMPION_START_TIMEOUT=90 git push"
    info ""
    info "Or use emergency override:"
    info "  SKIP_CHAMPION_CHECK=1 SKIP_REASON=\"startup timeout\" git push"
    exit 1
fi
ok "Streamlit ready on http://localhost:${TEST_PORT}"

# ─────────────────────────────────────────────────────────────────────────────
# 7.  Run the regression test
# ─────────────────────────────────────────────────────────────────────────────
echo ""
info "Running regression test..."
echo ""

cd "${REPO_ROOT}"

export CHAMPION_TEST_URL="http://localhost:${TEST_PORT}"

if python3 -m pytest \
    "${TEST_FILE}::test_champion_badge_no_ranking_data_regression" \
    --tb=short \
    --no-header \
    -q \
    2>&1; then

    echo ""
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}${BOLD}  ✅ CHAMPION guard PASSED${NC}"
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    # Continue to critical E2E validation (don't exit yet)

else
    echo ""
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}${BOLD}  ❌ CHAMPION guard FAILED — PUSH BLOCKED${NC}"
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${RED}  REGRESSION: CHAMPION badge shows 'No ranking data'${NC}"
    echo ""
    echo "  Debug steps:"
    echo "  1. Screenshot: tests_e2e/screenshots/champion_badge_FAILED.png"
    echo "  2. Streamlit log: ${STREAMLIT_LOG}"
    echo "  3. Verify CHAMPION guard is active in performance_card.py"
    echo "  4. Verify badge_metadata.placement is set in DB"
    echo ""
    echo -e "${YELLOW}  Emergency override (SKIP_REASON required):${NC}"
    echo "    SKIP_CHAMPION_CHECK=1 SKIP_REASON=\"<your reason>\" git push"
    echo ""
    exit 1
fi

# =============================================================================
# GUARD 2: Critical E2E Suite Validation (main/develop branches only)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 0.  Detect target branch from git push arguments
# ─────────────────────────────────────────────────────────────────────────────
# Git pre-push hook receives: <local ref> <local sha1> <remote ref> <remote sha1>
# We need to check if the remote ref is refs/heads/main or refs/heads/develop

# Read from stdin (git provides push details)
PUSH_TO_PROTECTED=0
while read local_ref local_sha remote_ref remote_sha; do
    if [[ "${remote_ref}" == "refs/heads/main" ]] || [[ "${remote_ref}" == "refs/heads/develop" ]]; then
        PUSH_TO_PROTECTED=1
        PROTECTED_BRANCH="${remote_ref#refs/heads/}"
        break
    fi
done

# If not pushing to protected branches, skip critical E2E validation
if [[ ${PUSH_TO_PROTECTED} -eq 0 ]]; then
    echo ""
    ok "Not pushing to main/develop — skipping critical E2E validation"
    echo ""
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}${BOLD}  ✅ All guards PASSED — push allowed${NC}"
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# 1.  SKIP override for critical E2E validation
# ─────────────────────────────────────────────────────────────────────────────
if [[ "${SKIP_CRITICAL_E2E:-0}" == "1" ]]; then
    if [[ -z "${SKIP_REASON:-}" ]]; then
        err "SKIP_CRITICAL_E2E=1 requires SKIP_REASON to be set."
        err "Example:  SKIP_CRITICAL_E2E=1 SKIP_REASON=\"docs-only change\" git push"
        exit 1
    fi

    CRITICAL_E2E_AUDIT_LOG="${REPO_ROOT}/.git/hooks/critical_e2e_skip_audit.log"
    mkdir -p "$(dirname "${CRITICAL_E2E_AUDIT_LOG}")"
    printf '%s  SKIP  branch=%s  target=%s  user=%s  reason=%s\n' \
        "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" \
        "$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')" \
        "${PROTECTED_BRANCH}" \
        "$(git config user.email 2>/dev/null || echo 'unknown')" \
        "${SKIP_REASON}" \
        >> "${CRITICAL_E2E_AUDIT_LOG}"

    echo ""
    warn "Critical E2E validation SKIPPED — recorded in audit log"
    warn "Skip reason : ${SKIP_REASON}"
    warn "Audit log   : ${CRITICAL_E2E_AUDIT_LOG}"
    echo ""
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}${BOLD}  ✅ All guards PASSED (with skip) — push allowed${NC}"
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 0
fi

# ─────────────────────────────────────────────────────────────────────────────
# 2.  Run Critical E2E Suite Validation
# ─────────────────────────────────────────────────────────────────────────────
echo ""
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}${BOLD}  🔒 Critical E2E Suite Validation (${PROTECTED_BRANCH})${NC}"
echo -e "${CYAN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

warn "Pushing to ${PROTECTED_BRANCH} — running 170 critical E2E tests"
info "This may take 5-10 minutes..."
echo ""

VALIDATION_SCRIPT="${REPO_ROOT}/scripts/validate_critical_e2e.sh"

if [[ ! -x "${VALIDATION_SCRIPT}" ]]; then
    err "Validation script not found or not executable: ${VALIDATION_SCRIPT}"
    info ""
    info "Push blocked. Fix the script or use:"
    info "  SKIP_CRITICAL_E2E=1 SKIP_REASON=\"script missing\" git push"
    exit 1
fi

if "${VALIDATION_SCRIPT}"; then
    echo ""
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}${BOLD}  ✅ All guards PASSED (Champion + Critical E2E) — push allowed${NC}"
    echo -e "${GREEN}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    exit 0
else
    echo ""
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}${BOLD}  ❌ CRITICAL E2E VALIDATION FAILED — PUSH BLOCKED${NC}"
    echo -e "${RED}${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${RED}  FAILURE: Critical E2E suite did not pass 170/170 tests${NC}"
    echo ""
    echo "  Debug steps:"
    echo "  1. Review screenshots: tests_cypress/cypress/screenshots/"
    echo "  2. Review videos: tests_cypress/cypress/videos/"
    echo "  3. Run locally: ./scripts/validate_critical_e2e.sh"
    echo ""
    echo -e "${YELLOW}  Emergency override (SKIP_REASON required):${NC}"
    echo "    SKIP_CRITICAL_E2E=1 SKIP_REASON=\"<your reason>\" git push"
    echo ""
    exit 1
fi

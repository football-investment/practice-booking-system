# Staging environment variables — set these in Vercel Dashboard, not in code.
# This file documents the required keys. Values are never committed.

DATABASE_URL=postgresql://user:password@host:5432/staging_db
JWT_SECRET_KEY=generate-a-unique-staging-secret
APP_NAME=LFA Staging API

# The 118-migration / 135-table schema is applied to a dedicated Neon staging DB.
# This is a temporary staging decision. Production and local DBs are never touched.

# Redis is NOT required — the staging scope has no Celery, scheduler, or pub/sub.
# REDIS_URL is intentionally absent.
